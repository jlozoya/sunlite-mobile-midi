{
  "name": "sunlite-mobile-midi-react",
  "version": "0.1.0",
  "private": true,
  "description": "Installable mobile MIDI controller for Sunlite Suite 2.",
  "author": "",
  "type": "module",
  "main": "dist/main/main.js",
  "scripts": {
    "clean": "rimraf dist release",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit",
    "build:main": "tsc -p tsconfig.node.json",
    "build:renderer": "vite build",
    "build": "bun run build:main && bun run build:renderer",
    "start": "bun run build && electron dist/main/main.js",
    "pack": "bun run build && electron-builder --dir",
    "dist": "bun run build && electron-builder"
  },
  "dependencies": {
    "@stylexjs/stylex": "^0.9.3",
    "easymidi": "^3.1.0",
    "express": "^4.19.2",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-aria-components": "^1.8.0",
    "react-dom": "^19.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-stylex": "^0.13.0"
  },
  "build": {
    "appId": "com.sunlite.mobilemidi",
    "productName": "Sunlite Mobile MIDI",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "extraResources": [
      {
        "from": "resources/installers",
        "to": "installers",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
