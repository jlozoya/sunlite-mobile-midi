{
  "name": "sunlite-mobile-midi",
  "version": "0.2.0",
  "private": true,
  "description": "Installable and update-ready mobile MIDI controller for Sunlite Suite 2.",
  "author": "jlozoya",
  "type": "module",
  "main": "dist/main/main.js",
  "scripts": {
    "clean": "rimraf dist release",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit",
    "check": "bun run format:check && bun run typecheck",
    "build:main": "tsc -p tsconfig.node.json",
    "build:renderer": "vite build",
    "build": "bun run format:check && bun run build:main && bun run build:renderer",
    "start": "bun run build && electron dist/main/main.js",
    "pack": "bun run build && electron-builder --dir",
    "dist": "bun run build && electron-builder",
    "dist:win": "bun run build && electron-builder --win",
    "release:win": "bun run build && electron-builder --win --publish never"
  },
  "dependencies": {
    "@stylexjs/stylex": "^0.9.3",
    "easymidi": "^3.1.0",
    "electron-updater": "^6.3.9",
    "express": "^4.19.2",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-aria-components": "^1.8.0",
    "react-dom": "^19.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-stylex": "^0.13.0"
  },
  "build": {
    "appId": "com.lozoya.sunlite.mobilemidi",
    "productName": "Sunlite Mobile MIDI",
    "directories": {
      "output": "release",
      "buildResources": "resources"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "icon": "resources/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Sunlite Mobile MIDI",
      "deleteAppDataOnUninstall": false
    },
    "extraResources": [
      {
        "from": "resources/installers",
        "to": "installers",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/icon.png",
        "to": "icon.png"
      },
      {
        "from": "resources/icon.ico",
        "to": "icon.ico"
      }
    ],
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "publish": [
      {
        "provider": "generic",
        "url": "https://example.com/sunlite-mobile-midi/updates"
      }
    ]
  }
}
